{
  "name": "@postman-cse/onboarding-repo-sync",
  "version": "0.13.0",
  "description": "Public open-alpha Postman repo sync GitHub Action.",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "postman-repo-sync": "dist/cli.cjs"
  },
  "files": [
    "action.yml",
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run typecheck && rm -rf dist && esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs && esbuild src/cli.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/cli.cjs",
    "check:dist": "npm run build && git diff --exit-code -- dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "github-action",
    "postman"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "undici": "^6.24.0",
    "picomatch": ">=4.0.4"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/postman-cs/postman-repo-sync-action"
  }
}
